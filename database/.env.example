# Database Configuration for Canberra Vision Detection System
# PostgreSQL Database Settings

DB_HOST=localhost
DB_PORT=5432
DB_NAME=canberraavisison_detection
DB_USER=postgres
DB_PASSWORD=admin
DB_SSL=false
DB_SSLMODE=disable
DB_CONNECT_TIMEOUT=10
DB_POOL_SIZE=20

# Application Settings
APPLICATION_NAME=canberra_vision_detection_system

# Optional: Database connection pool settings
DB_POOL_MIN=1
DB_POOL_MAX=20
DB_POOL_TIMEOUT=30
